#/bin/sh

set -e

cd /tmp
wget https://github.com/AndreRH/hangover/releases/download/hangover-11.9/hangover_11.9_debian13_trixie_arm64.tar
tar -xvf hangover_11.9_debian13_trixie_arm64.tar
cd hangover_11.9_debian13_trixie_arm64
apt install -y ./hangover*.deb

cd /tmp
rm -rf hangover_11.9_debian13_trixie_arm64*