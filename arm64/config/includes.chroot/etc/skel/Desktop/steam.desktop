[Desktop Entry]
Type=Application
Version=1.0
Name=Steam
GenericName=Free-form Game Emulation Platform
Comment=Play games on Steam via FEX-Emu
Exec=FEXBash steam %U
Icon=steam
Terminal=false
MimeType=x-scheme-handler/steam;x-scheme-handler/steamlink;
Categories=Game;Amusement;
Keywords=Games;Store;Launcher;FEX;

# KDE-Specific Tweaks
X-KDE-StartupNotify=true
X-KDE-UniqueApplet=true
X-KDE-Keywords=gaming,steam,fex,emulation