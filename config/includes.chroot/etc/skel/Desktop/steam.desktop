[Desktop Entry]
Name=Steam
Comment=Play games on ARM64 Linux
Exec=/usr/local/bin/steam-arm64 %U
Icon=steam
Terminal=false
Type=Application
Categories=Game;Network;
MimeType=x-scheme-handler/steam;

# KDE-Specific Tweaks
X-KDE-StartupNotify=true
X-KDE-UniqueApplet=true
X-KDE-Keywords=gaming,steam,fex,emulation